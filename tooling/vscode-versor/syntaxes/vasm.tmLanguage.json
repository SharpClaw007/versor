{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Versor Assembly",
  "scopeName": "source.vasm",
  "fileTypes": [
    "vasm"
  ],
  "patterns": [
    {
      "match": "[;#].*$",
      "name": "comment.line.vasm"
    },
    {
      "match": "^\\s*\\.(name|decoder|chain)\\b",
      "name": "keyword.control.directive.vasm"
    },
    {
      "match": "^\\s*([A-Za-z_]\\w*):",
      "captures": {
        "1": {
          "name": "entity.name.label.vasm"
        }
      }
    },
    {
      "match": "->\\s*([A-Za-z_]\\w*)",
      "captures": {
        "1": {
          "name": "entity.name.label.reference.vasm"
        }
      }
    },
    {
      "match": "\\b(LOADI|STORE|LOAD|MOVR|MOVA|HALT|ADD|SUB|SCALE|DOT|CROSS|NORM|PROJ|REJ|ROTF|ROTG|ROTH|OUT|OUTC|CALL|RET|JMPZ|JMPP|PUSHF|POPF|NOP|FAULT|BR|SEG|SEGRAW|OP|EXEC|INP|SWAP|PUSHA|POPA|MULR|LOADP)\\b",
      "name": "keyword.mnemonic.vasm"
    },
    {
      "match": "\\b[rR][0-3]\\b",
      "name": "variable.language.register.vasm"
    },
    {
      "match": "[+-]?[xyz]\\b(?=\\s*:)",
      "name": "constant.language.guard.vasm"
    },
    {
      "match": "\\b\\d+\\.?\\d*\\s*\\*?\\s*pi(\\s*/\\s*\\d+\\.?\\d*)?|\\bpi(\\s*/\\s*\\d+\\.?\\d*)?",
      "name": "constant.numeric.angle.vasm"
    },
    {
      "match": "\\b\\d+(\\.\\d+)?\\b",
      "name": "constant.numeric.vasm"
    }
  ]
}