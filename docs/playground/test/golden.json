60254037844388, 0.8660254037844388, 0.8660254037844388], "to": 2}]}, {"id": 2, "out": [{"seg": [0.0, -0.7071067811865475, -0.7071067811865475], "to": 3}]}, {"id": 3, "out": [{"seg": [0.0, -2.221441469079183, 2.221441469079183], "to": 4}]}, {"id": 4, "out": [{"seg": [-0.8660254037844389, -0.8660254037844387, 0.8660254037844388], "to": 5}]}, {"id": 5, "out": [{"seg": [8.659560562354932e-17, 0.7071067811865475, -0.7071067811865475], "to": 6}]}, {"id": 6, "out": [{"seg": [0.0, 0.0, -1.0], "to": 7}]}, {"id": 7, "out": []}]}, {"id": 1, "comment": "fork", "vertices": [{"id": 0, "out": [{"seg": [0.6, 0.0, 0.0], "to": 1, "guard": [1.0, 0.0, 0.0]}, {"seg": [2.5, 0.0, 0.0], "to": 2, "guard": [-1.0, 0.0, 0.0]}]}, {"id": 1, "out": []}, {"id": 2, "out": []}]}]}, "expected": {"out": [0.6000000000000001, -2.4999999999999996], "haltReason": "HALT", "steps": 11, "displacement": [4.1, -2.221441469079183, 1.5392787142749658], "opcodes": ["LOADI", "CALL", "LOADI", "RET*", "OUT", "ROTH", "CALL", "STORE", "RET*", "OUT", "HALT"]}, "vasm": "; add_two (M3) in Versor assembly: orientation is the argument.\n; The same chain is called twice; the pi frame rotation between the calls\n; flips which branch arm wins, so the two calls sweep different displacements.\n\n.name add_two\n\n.chain main\n        LOADI 1          ; A = world +x, the branch input for both calls\n        CALL fork\n        OUT              ; prints 0.6\n        ROTH pi          ; segments after this are re-aimed automatically\n        CALL fork\n        OUT              ; prints -2.5\n        HALT\n\n.chain fork\n        BR (1,0,0): LOADI 0.6 -> a, (-1,0,0): LOADI 2.5 -> b\n        ; a and b are never defined: dead-end vertices, implicit RET\n"}]